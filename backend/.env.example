# Environment variables
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/lifebotai

# JWT Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Telegram Bot (Step 1.4)
# Obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Full HTTPS URL where Telegram delivers webhook updates, e.g.:
# https://your-domain.com/bot/webhook
WEBHOOK_URL=https://your-domain.com/bot/webhook

# AI Provider (Step 1.4) — leave blank to use the built-in mock AI
# Set to an OpenAI-compatible API key to enable real AI responses
OPENAI_API_KEY=
